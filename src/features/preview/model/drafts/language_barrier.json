  "grammarNotes": {
    "wa": {
      "id": "wa",
      "title": { "ru": "wa (は) — частица темы" },
      "body": [
        {
          "summary": {
            "ru": "Помечает тему — то, О ЧЁМ фраза. Схема: [тема] wa […]. Читается как «что касается …»."
          },
          "details": [
            { "ru": "Пишется знаком は («ха»), но как частица читается «wa / ва»." },
            {
              "ru": "Ставится сразу после того, что делаешь темой: eigo wa… (эйго ва) — «насчёт английского…»."
            }
          ],
          "examples": [
            {
              "kind": "phrase",
              "forms": [{ "surface": "これは", "romaji": "kore wa", "cyrillic": "корэ ва" }],
              "note": { "ru": "что касается этого" }
            },
            {
              "kind": "phrase",
              "forms": [
                {
                  "surface": "英語は話せますか",
                  "romaji": "eigo wa hanasemasu ka",
                  "cyrillic": "эйго ва ханасэмас ка"
                }
              ],
              "note": { "ru": "вы говорите по-английски?" }
            }
          ]
        }
      ],
      "deeper": [
        {
          "summary": {
            "ru": "С глаголами возможности тему-объект часто маркируют не wa, а ga. ga — нейтральнее, wa — «именно про это / как тему». Оба верны."
          },
          "examples": [
            {
              "kind": "phrase",
              "forms": [
                {
                  "surface": "英語が話せますか",
                  "romaji": "eigo ga hanasemasu ka",
                  "cyrillic": "эйго га ханасэмас ка"
                }
              ],
              "note": { "ru": "вы говорите по-английски? (нейтрально)" }
            }
          ]
        }
      ]
    },
    "potential": {
      "id": "potential",
      "title": { "ru": "hanasemasu / hanasemasen — «могу / не могу»" },
      "body": [
        {
          "summary": {
            "ru": "hanasemasu — «могу говорить», hanasemasen — «не могу». Это потенциальная форма глагола hanasu (говорить)."
          },
          "details": [
            {
              "ru": "hanasu (говорить) → hanaseru → вежливо hanasemasu (ханасэмас, «могу говорить»)."
            },
            { "ru": "Отрицание: hanasemasu → hanasemasen (ханасэмасэн, «не могу говорить»)." },
            { "ru": "Не путать с hanashimasu (ханасимас) — это просто «говорю», без «могу»." }
          ],
          "examples": [
            {
              "kind": "transform",
              "from": { "surface": "話せます", "romaji": "hanasemasu", "cyrillic": "ханасэмас" },
              "to": { "surface": "話せません", "romaji": "hanasemasen", "cyrillic": "ханасэмасэн" },
              "note": { "ru": "могу → не могу" }
            }
          ]
        }
      ],
      "deeper": [
        {
          "summary": { "ru": "Общее правило: как из любого глагола сделать «могу»." },
          "details": [
            { "ru": "Глаголы на -u: последний -u → -e + ru: hanasu → hanaseru, nomu → nomeru." },
            { "ru": "Глаголы на -ru: -ru → -rareru: taberu → taberareru («могу есть»)." }
          ],
          "examples": [
            {
              "kind": "transform",
              "from": { "surface": "飲む", "romaji": "nomu", "cyrillic": "ному" },
              "to": { "surface": "飲める", "romaji": "nomeru", "cyrillic": "номэру" },
              "note": { "ru": "пить → могу пить" }
            },
            {
              "kind": "transform",
              "from": { "surface": "食べる", "romaji": "taberu", "cyrillic": "табэру" },
              "to": { "surface": "食べられる", "romaji": "taberareru", "cyrillic": "табэрарэру" },
              "note": { "ru": "есть → могу есть" }
            }
          ]
        }
      ]
    },
    "ka": {
      "id": "ka",
      "title": { "ru": "ka (か) — вопрос" },
      "body": [
        {
          "summary": { "ru": "В вежливой речи ka в конце делает фразу вопросом." },
          "details": [
            { "ru": "hanasemasu → hanasemasu ka (ханасэмас ка) — «можешь говорить?»." },
            {
              "ru": "С вопросительным словом тоже: ikura desu ka (икура дэс ка) — «сколько стоит?»."
            },
            { "ru": "Правило: вежливо (desu/masu) + вопрос → добавляй ka." }
          ],
          "examples": [
            {
              "kind": "transform",
              "from": { "surface": "話せます", "romaji": "hanasemasu", "cyrillic": "ханасэмас" },
              "to": {
                "surface": "話せますか",
                "romaji": "hanasemasu ka",
                "cyrillic": "ханасэмас ка"
              },
              "note": { "ru": "утверждение → вопрос" }
            }
          ]
        }
      ],
      "deeper": [
        {
          "summary": { "ru": "В разговорной речи ka часто опускают и поднимают интонацию." },
          "details": [
            { "ru": "Простая форма + интонация: hanaseru? (ханасэру)." },
            { "ru": "ka к простой форме (hanaseru ka) звучит резко, как допрос." }
          ]
        }
      ]
    },
    "go": {
      "id": "go",
      "title": { "ru": "-go (語) — суффикс «язык»" },
      "body": [
        {
          "summary": {
            "ru": "Названия языков = страна/народ + go (го). Узнал суффикс — узнаёшь все языки."
          },
          "details": [
            { "ru": "eigo (эйго) — английский, nihongo (нихонго) — японский." },
            { "ru": "roshiago (росиаго) — русский: Roshia (Россия) + go." },
            { "ru": "chūgokugo (тю:гокуго) — китайский, furansugo (фурансуго) — французский." }
          ],
          "examples": [
            {
              "kind": "phrase",
              "forms": [
                { "surface": "ロシア + 語", "romaji": "roshia + go", "cyrillic": "росиа + го" }
              ],
              "note": { "ru": "Россия + «язык» = русский" }
            }
          ]
        }
      ]
    },
    "dake": {
      "id": "dake",
      "title": { "ru": "dake (だけ) — «только»" },
      "body": [
        {
          "summary": { "ru": "Ставится после слова: «только/лишь»." },
          "details": [
            {
              "ru": "sukoshi (сукоси) — «немного»; + dake усиливает: sukoshi dake — «совсем чуть-чуть»."
            },
            { "ru": "Частый ответ «да, немного»: hai, sukoshi dake (хай, сукоси дакэ)." }
          ],
          "examples": [
            {
              "kind": "phrase",
              "forms": [
                { "surface": "少しだけ", "romaji": "sukoshi dake", "cyrillic": "сукоси дакэ" }
              ],
              "note": { "ru": "совсем чуть-чуть" }
            }
          ]
        }
      ],
      "deeper": [
        {
          "summary": {
            "ru": "В разговоре вместо sukoshi часто chotto (тётто) — то же, но менее формально."
          },
          "examples": [
            {
              "kind": "phrase",
              "forms": [
                { "surface": "ちょっとだけ", "romaji": "chotto dake", "cyrillic": "тётто дакэ" }
              ],
              "note": { "ru": "чуть-чуть (разговорно)" }
            }
          ]
        }
      ]
    },
    "omit-pronoun": {
      "id": "omit-pronoun",
      "title": { "ru": "Почему нет «я» и «вы»" },
      "body": [
        {
          "summary": {
            "ru": "Японский опускает местоимения, когда ясно из контекста. Подлежащее достраивается само."
          },
          "details": [
            { "ru": "hanasemasen без «я» → по умолчанию про говорящего: «я не могу»." },
            { "ru": "hanasemasu ka без «вы» → вопрос обращён к собеседнику: «вы можете?»." },
            { "ru": "Глагол не меняется по лицам — кто действует, ясно из ситуации." },
            {
              "ru": "Добавлять watashi (ватаси, «я») / anata (аната, «вы») каждый раз звучит неестественно, а anata в лицо часто невежливо."
            }
          ],
          "examples": [
            {
              "kind": "plain",
              "text": {
                "ru": "hanasemasu = «(я) могу говорить»; hanasemasu ka = «(вы) можете?» — одно слово, разница в ka и контексте."
              }
            }
          ]
        }
      ]
    }
  },
