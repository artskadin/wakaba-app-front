  "grammarNotes": {
    "wa": {
      "id": "wa",
      "title": { "ru": "は — частица темы (читается «ва»!)" },
      "body": {
        "ru": "Помечает тему фразы. Пишется знаком は (ха), но как частица читается «ва» — как и を."
      },
      "examples": [
        {
          "kind": "phrase",
          "forms": [{ "surface": "これは", "romaji": "kore wa" }],
          "note": { "ru": "что касается этого" }
        }
      ]
    },
    "ikura": {
      "id": "ikura",
      "title": { "ru": "いくら — «сколько (стоит)»" },
      "body": { "ru": "Спрашивает цену, ставится перед です." },
      "examples": [
        {
          "kind": "phrase",
          "forms": [{ "surface": "いくらですか", "romaji": "ikura desu ka" }],
          "note": { "ru": "сколько стоит?" }
        }
      ]
    },
    "desu": {
      "id": "desu",
      "title": { "ru": "です — вежливая связка" },
      "body": {
        "ru": "Завершает фразу вежливо, на русский отдельно не переводится. Читается «дэс»."
      },
      "examples": []
    },
    "ka": {
      "id": "ka",
      "title": { "ru": "か — вопросительная частица" },
      "body": { "ru": "В конце фразы превращает утверждение в вопрос." },
      "examples": [
        {
          "kind": "transform",
          "from": { "surface": "です", "romaji": "desu" },
          "to": { "surface": "ですか", "romaji": "desu ka" }
        }
      ]
    },
    "hon": {
      "id": "hon",
      "title": { "ru": "本 — счётчик бутылок/банок" },
      "body": {
        "ru": "Считает бутылки, банки, длинные предметы. Звук меняется: 一本 ippon, 二本 nihon, 三本 sanbon."
      },
      "examples": [
        {
          "kind": "phrase",
          "forms": [{ "surface": "二本ください", "romaji": "nihon kudasai" }],
          "note": { "ru": "дайте две" }
        }
      ]
    },
    "hundreds": {
      "id": "hundreds",
      "title": { "ru": "六百 — 600 (роппяку)" },
      "body": { "ru": "Сотни меняют звук: 300 sanbyaku, 600 roppyaku, 800 happyaku." },
      "examples": []
    },
    "kudasai": {
      "id": "kudasai",
      "title": { "ru": "ください — «дайте, пожалуйста»" },
      "body": { "ru": "Вежливая просьба дать предмет." },
      "examples": []
    },
    "irimasu": {
      "id": "irimasu",
      "title": { "ru": "いります — «нужен / требуется»" },
      "body": { "ru": "Вежливая форма 要る (iru). 袋はいりますか = «пакет нужен?»." },
      "examples": []
    },
    "onegai": {
      "id": "onegai",
      "title": { "ru": "お願いします — «прошу / пожалуйста»" },
      "body": { "ru": "Универсальная вежливая просьба. Здесь = «да, давайте»." },
      "examples": []
    }
  },
